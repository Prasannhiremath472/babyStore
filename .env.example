# ========================
# LittleNest Environment
# ========================

# Database
POSTGRES_DB=littlenest
POSTGRES_USER=littlenest_user
POSTGRES_PASSWORD=littlenest_secret
DATABASE_URL=postgresql://littlenest_user:littlenest_secret@localhost:5432/littlenest

# Redis
REDIS_URL=redis://localhost:6379

# Backend
NODE_ENV=development
PORT=4000
API_VERSION=v1

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@littlenest.in
FROM_NAME=LittleNest

# Frontend URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# AWS S3 (optional alternative to Cloudinary)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=littlenest-assets

# App
APP_NAME=LittleNest
APP_DOMAIN=littlenest.in
